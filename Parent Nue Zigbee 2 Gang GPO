def installed() {
    logInfo("Installed")
    initialize()
}

def updated() {
    logInfo("Configuration saved")
    if (settings.enableDebug) {
        logWarn("Debug logging will be automatically disabled in 30 minutes.")
        runIn(1800, logsOff)
    }
    initialize()
}

def initialize() {
    logInfo("Initialize")
    state.lastSwitch = 0

    if (enableDebug) {
        logInfo("Verbose logging enabled for 30 minutes.")
        runIn(1800, logsOff)
    }

    configure()
}

def parse(String description) {
    logTrace("Msg: Description is ${description}")

    def event = zigbee.getEvent(description)
    def msg = zigbee.parseDescriptionAsMap(description)

    if (event) {
        if (event.name == "power") {
            def rawPower = event.value as int
            def powerValue = rawPower / 10
            if (powerValue < 1) powerValue = 0
            event = createEvent(name: event.name, value: powerValue, descriptionText: "${device.displayName} power is ${powerValue} watts")
            logTrace("${device.displayName} power is ${powerValue} watts")
        } else if (event.name == "switch") {
            def descriptionText = (event.value == "on") ? "${device.displayName} is On" : "${device.displayName} is Off"
            event = createEvent(name: event.name, value: event.value, descriptionText: descriptionText)

            if (event.value == "off") {
                sendEvent(name: "power", value: 0, descriptionText: "${device.displayName} power is 0 watts")
            }

            def childEndpoint = msg?.sourceEndpoint ?: msg?.endpoint
            if (childEndpoint) {
                def childDevice = getChildDevice(getChildNetworkId(childEndpoint))
                if (childDevice) {
                    logDebug("Passing switch event to child ${childDevice.displayName}")
                    childDevice.parse([event])
                } else {
                    logDebug("Child device not found for endpoint ${childEndpoint}")
                }
            }
            state.lastSwitch = now()
        }
        return createEvent(event)
    } 
    else if (msg) {
        if (!msg.cluster) {
            logDebug("Message has null cluster, raw description: ${description}")
            def clusterMatch = (description =~ /catchall:.*? ([0-9A-Fa-f]{4}) /)
            if (clusterMatch && clusterMatch.size() > 0) {
                def cluster = clusterMatch[0][1]
                logDebug("Extracted cluster from description: ${cluster}")
                // Optional: handle cluster if needed
            }
            return null
        }

        switch (msg.cluster) {
            case "0B04":
                try {
                    def attrId = msg.attrId
                    def valueHex = msg.value
                    def endpoint = msg.sourceEndpoint ?: msg.endpoint ?: 1
                    def childDevice = getChildDevice(getChildNetworkId(endpoint))

                    def powerValue = null
                    def voltageValue = null
                    def currentValue = null

                    if (attrId && valueHex) {
                        def valueInt = Integer.parseInt(valueHex, 16)
                        switch (attrId.toLowerCase()) {
                            case "0505":
                                voltageValue = valueInt
                                sendEvent(name: "voltage", value: voltageValue, unit: "V", descriptionText: "${device.displayName} voltage is ${voltageValue} volts")
                                logDebug("${device.displayName} voltage is ${voltageValue} volts")
                                break
                            case "050b":
                                powerValue = valueInt
                                if (powerValue < 1) powerValue = 0
                                sendEvent(name: "power", value: powerValue, unit: "W", descriptionText: "${device.displayName} power is ${powerValue} watts")
                                logDebug("${device.displayName} power is ${powerValue} watts")
                                break
                            case "0508":
                                currentValue = valueInt / 1000.0
                                sendEvent(name: "amperage", value: currentValue, unit: "A", descriptionText: "${device.displayName} RMS current is ${currentValue} A")
                                logDebug("${device.displayName} RMS current is ${currentValue} A")
                                break
                            default:
                                logDebug("Unhandled electrical measurement attrId ${attrId} with value ${valueInt}")
                        }
                    }

                    if (msg.additionalAttrs) {
                        msg.additionalAttrs.each { attr ->
                            def aId = attr.attrId
                            def aValHex = attr.value
                            if (aId && aValHex) {
                                def aValInt = Integer.parseInt(aValHex, 16)
                                switch (aId.toLowerCase()) {
                                    case "0505":
                                        voltageValue = aValInt
                                        sendEvent(name: "voltage", value: voltageValue, unit: "V", descriptionText: "${device.displayName} voltage is ${voltageValue} volts")
                                        logDebug("${device.displayName} voltage is ${voltageValue} volts")
                                        break
                                    case "050b":
                                        powerValue = aValInt
                                        if (powerValue < 1) powerValue = 0
                                        sendEvent(name: "power", value: powerValue, unit: "W", descriptionText: "${device.displayName} power is ${powerValue} watts")
                                        logDebug("${device.displayName} power is ${powerValue} watts")
                                        break
                                    case "0508":
                                        currentValue = aValInt / 1000.0
                                        sendEvent(name: "amperage", value: currentValue, unit: "A", descriptionText: "${device.displayName} RMS current is ${currentValue} A")
                                        logDebug("${device.displayName} RMS current is ${currentValue} A")
                                        break
                                    default:
                                        logDebug("Unhandled electrical measurement additional attrId ${aId} with value ${aValInt}")
                                }
                            }
                        }
                    }

                    if (childDevice) {
                        def dataToSend = [:]
                        if (powerValue != null) dataToSend.power = powerValue
                        if (voltageValue != null) dataToSend.voltage = voltageValue
                        if (currentValue != null) dataToSend.current = currentValue
                        if (dataToSend) {
                            childDevice.setPowerData(dataToSend)
                        }
                    }
                } catch (Exception e) {
                    logWarn("Error parsing electrical measurement catchall message: ${e}")
                }
                return null

            case "0006":
                if (msg.command == "01" || msg.command == "00") {
                    def onOffValue = (msg.command == "01") ? "on" : "off"
                    def endpoint = msg.sourceEndpoint ?: msg.endpoint
                    logInfo("Received ON/OFF command ${onOffValue.toUpperCase()} on endpoint ${endpoint}")
                    state.lastSwitch = now()
                    return createEvent(name: "switch", value: onOffValue, descriptionText: "${device.displayName} switched ${onOffValue} on endpoint ${endpoint}")
                }
                break

            case "8021":
                logInfo("Bind response received")
                return null

            default:
                logDebug("Received unhandled message cluster ${msg.cluster} with command ${msg.command}")
                return null
        }
    }

    logWarn("DID NOT PARSE MESSAGE for description: ${description}")
    return null
}

private onOffClusterCommand(int destEndpoint, int command) {
    logInfo("onOffClusterCommand(${destEndpoint}, ${command})")
    if (destEndpoint < 0x01 || destEndpoint > 0x02) {
        logError("Unknown target endpoint ${destEndpoint}")
        return null
    }
    if (command < 0x00 || command > 0x02) {
        logError("Unknown command for onOffCluster")
        return null
    }
    // The original "he cmd ..." string looks like a placeholder; you might want to replace it with actual Hubitat Zigbee command syntax if needed.
    return "he cmd 0x${device.deviceNetworkId} 0x${destEndpoint} 0x${zigbee.ON_OFF_CLUSTER} 0x${command} {}, delay 200"
}

def on(int destEndpoint) {
    onOffClusterCommand(destEndpoint, 0x01)
}

def off(int destEndpoint) {
    onOffClusterCommand(destEndpoint, 0x00)
}

def toggle(int destEndpoint) {
    onOffClusterCommand(destEndpoint, 0x02)
}

def on() {
    [on(0x01), on(0x02)]
}

def off() {
    [off(0x01), off(0x02)]
}

def toggle() {
    [toggle(0x01), toggle(0x02)]
}

def identify() {
    zigbee.writeAttribute(0x0003, 0x0000, DataType.UINT16, 0x00A, [:], 200)
}

def resetToFactoryDefault() {
    logWarn("Resetting device to factory defaults...")
    zigbee.command(0x0000, 0x00, [:], 200)
    runIn(1, configure)
}

def refresh() {
    def cmds = []
    for (endpoint in 1..2) {
        cmds += ["he rattr 0x${device.deviceNetworkId} ${endpoint} 6 0 {}", "delay 1000"]
    }
    cmds += zigbee.electricMeasurementPowerRefresh(1000) // Watts
    cmds += zigbee.readAttribute(0x0B04, 0x0505, [:], 1000) // Volts
    cmds += zigbee.readAttribute(0x0B04, 0x0508, [:], 1000) // Amps
    return cmds
}

def getDestinationEndpoint(childDevice) {
    def epId = childDevice.deviceNetworkId.split('-')[1]
    return Integer.parseInt(epId, 16)
}

def getChildNetworkId(destinationEndpoint) {
    def destEndpoint = (destinationEndpoint instanceof Integer) ?
        destinationEndpoint :
        Integer.parseInt(destinationEndpoint, 16)

    return "${device.deviceNetworkId}-${destEndpoint}"
}

def getChildLabel(destinationEndpoint) {
    switch (destinationEndpoint) {
        case 2: return "Right GPO"
        case 1: return "Left GPO"
        default: return "GPO ${destinationEndpoint}"
    }
}

def componentOn(child) {
    logDebug("componentOn(${child.deviceNetworkId})")
    sendHubCommand(new hubitat.device.HubAction(on(getDestinationEndpoint(child)), hubitat.device.Protocol.ZIGBEE))
}

def componentOff(child) {
    logDebug("componentOff(${child.deviceNetworkId})")
    sendHubCommand(new hubitat.device.HubAction(off(getDestinationEndpoint(child)), hubitat.device.Protocol.ZIGBEE))
}

def componentRefresh(child) {
    logDebug("componentRefresh(${child.deviceNetworkId})")
    refresh()
}

def deleteChildDevices() {
    getChildDevices().each { deleteChildDevice(it.deviceNetworkId) }
}

def createChildDevices() {
    for (endpoint in 1..2) {
        def childDeviceNetworkId = getChildNetworkId(endpoint)
        def childLabel = getChildLabel(endpoint)
        def cd = getChildDevice(childDeviceNetworkId)
        if (!cd) {
            cd = addChildDevice("stu.m", "Nue Child GPO", childDeviceNetworkId, [label: childLabel, isComponent: true])
            logInfo("Created child device ${childLabel} with network ID ${childDeviceNetworkId}")
        } else {
            cd.label = childLabel
        }
    }
}

def configure() {
    logDebug("Configure called...")

    createChildDevices()

    def cmds = []

    for (endpoint in 1..2) {
        cmds += [
            "zdo bind ${device.deviceNetworkId} ${endpoint} 0x01 0x0006 {${device.zigbeeId}} {}",
            "delay 1000",
            "he cr 0x${device.deviceNetworkId} ${endpoint} 6 0 16 0 900 {}",
            "delay 1000"
        ]
    }
    cmds += powerConfig()
    cmds += refresh()

    return cmds
}

def powerConfig() {
    float minW = (minDeltaW != null) ? minDeltaW.toFloat() : 1.0
    float minA = (minDeltaA != null) ? minDeltaA.toFloat() : 0.1
    float minV = (minDeltaV != null) ? minDeltaV.toFloat() : 10.0

    int powerDelta = (int)(minW * 10)
    int currentDelta = (int)(minA * 1000)
    int voltageDelta = (int)(minV * 10)

    def cfg = []

    cfg += zigbee.configureReporting(zigbee.ELECTRICAL_MEASUREMENT_CLUSTER, 0x050B, DataType.INT16, (int)(intervalMin ?: 5), (int)(intervalMax ?: 600), powerDelta, [:], 1000)
    cfg += zigbee.configureReporting(zigbee.ELECTRICAL_MEASUREMENT_CLUSTER, 0x0505, DataType.UINT16, 120, (int)(intervalMax ?: 600), voltageDelta, [:], 1000)
    cfg += zigbee.configureReporting(zigbee.ELECTRICAL_MEASUREMENT_CLUSTER, 0x0508, DataType.UINT16, (int)(intervalMin ?: 5), (int)(intervalMax ?: 600), currentDelta, [:], 1000)

    return cfg
}

private logError(msg) {
    log.error msg
}

private logWarn(msg) {
    if (settings.enableInfo) log.warn msg
}

private logDebug(msg) {
    if (settings.enableDebug) log.debug msg
}

private logTrace(msg) {
    if (settings.enableDebug) log.trace msg
}

private logInfo(msg) {
    if (settings.enableInfo) log.info msg
}

def logsOff() {
    logWarn("Debug logging disabled...")
    device.updateSetting("enableDebug", [value: "false", type: "bool"])
}

def disableDebugLogging() {
    device.updateSetting("enableDebug", [value: "false", type: "bool"])
    logWarn("Debug logging disabled automatically after timeout.")
}
